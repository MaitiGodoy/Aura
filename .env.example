# === GEMINI LIVE API (5-KEY ROTATION) ===
# The router cycles through these on rate limits / quota exhaustion.
# At least one is required for voice features. All 5 recommended for resilience.
VITE_GOOGLE_KEY_1=AIzaSy...
VITE_GOOGLE_KEY_2=AIzaSy...
VITE_GOOGLE_KEY_3=AIzaSy...
VITE_GOOGLE_KEY_4=AIzaSy...
VITE_GOOGLE_KEY_5=AIzaSy...

# === GROQ API (TEXT LOGIC) ===
# Used for session summaries, lesson plans, chat — lightweight text processing
VITE_GROQ_API_KEY=gsk_...

# === SUPABASE (OPTIONAL) ===
# Leave empty for local-only mode
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
